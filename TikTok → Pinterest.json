    {
      "parameters": {
        "jsCode": "return items.map((item, i) => {\n\tconst meta = $('Code in JavaScript1').all()[i].json;\n\n\tlet keyword = 'healthy recipes';\n\ttry { keyword = $('Edit Fields').first().json.keyword || keyword; } catch(e) {\n\t\ttry { keyword = $('Set Schedule Keyword').first().json.keyword || keyword; } catch(e2) {}\n\t}\n\n\tlet raw = item.json.output ?? item.json.text ?? item.json;\n\n\tlet parsed;\n\tif (typeof raw === 'object' && raw !== null && (raw.title || raw.description)) {\n\t\tparsed = raw;\n\t} else {\n\t\tlet str = String(raw).replace(/```json|```/g, '').trim();\n\t\ttry {\n\t\t\tparsed = JSON.parse(str);\n\t\t} catch {\n\t\t\tconst match = str.match(/\\{[\\s\\S]*\\}/);\n\t\t\tif (match) {\n\t\t\t\ttry { parsed = JSON.parse(match[0]); } catch { parsed = { title: '', description: str }; }\n\t\t\t} else {\n\t\t\t\tparsed = { title: '', description: str };\n\t\t\t}\n\t\t}\n\t}\n\n\treturn {\n\t\tjson: {\n\t\t\ttimestamp: new Date().toISOString(),\n\t\t\tkeyword: keyword,\n\t\t\t...meta,\n\t\t\tpin_title: parsed.title || '',\n\t\t\tpin_description: parsed.description || '',\n\t\t\tstatus: 'Pending'\n\t\t}\n\t};\n});"
      },
