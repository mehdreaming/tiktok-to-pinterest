      "parameters": {
        "jsCode": "let keyword = '';\ntry {\n  keyword = ($('Edit Fields').first().json.keyword || '').toLowerCase();\n} catch (e) {\n  keyword = '';\n}\nconst terms = keyword.split(/\\s+/).filter(t => t.length >= 3);\n\nreturn items\n  .filter(item => {\n    if (terms.length === 0) return true;\n    const v = item.json;\n    const haystack = `${v.text || ''} ${v.authorMeta?.name || ''} ${v.authorMeta?.nickName || ''}`.toLowerCase();\n    return terms.some(t => haystack.includes(t));\n  })\n  .map(item => {\n    const v = item.json;\n    const vm = v.videoMeta || {};\n    const downloadUrl = vm.downloadAddr || vm.playAddr || vm.downloadLink || (Array.isArray(v.mediaUrls) && v.mediaUrls[0]) || null;\n    return {\n      json: {\n        id: v.id,\n        url: v.webVideoUrl,\n        author: v.authorMeta?.name,\n        views: v.playCount ?? 0,\n        shares: v.shareCount ?? 0,\n        likes: v.diggCount ?? 0,\n        duration: vm.duration ?? 0,\n        downloadUrl,\n        cover: vm.coverUrl || null,\n        caption: v.text || ''\n      }\n    };\n  });"
      },
