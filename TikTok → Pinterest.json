        "jsCode": "const existingUrls = new Set();\ntry {\n\tconst sheetRows = $('Get Existing URLs').all();\n\tfor (const row of sheetRows) {\n\t\tif (row.json.tiktok_url) existingUrls.add(row.json.tiktok_url);\n\t}\n} catch (e) {}\n\nconst candidates = $('Filter').all();\nconst fresh = candidates.filter(item => !existingUrls.has(item.json.url));\n\nconsole.log(`Dedup: ${candidates.length} → ${fresh.length} fresh (${existingUrls.size} in sheet)`);\n\nreturn fresh;"
